MONGO_URI=mongodb://127.0.0.1:27017/epsilock_phase2
JWT_SECRET=change_this_to_a_long_random_secret
PORT=4000
TLS_KEY_PATH=./certs/localhost-key.pem
TLS_CERT_PATH=./certs/localhost-cert.pem
ACCESS_TOKEN_TTL=10m
FILE_TTL_MS=120000
MAX_FILE_BYTES=1048576
MAX_FILE_SIZE_BYTES=1048576
ALLOWED_FILE_MIME_PREFIXES=image/,text/,application/pdf

# Phase 2 security controls
ALLOWED_ORIGINS=https://localhost:4000,http://localhost:4000
MAX_MESSAGES_PER_10_SECONDS=20
MAX_WS_EVENTS_PER_5_SECONDS=40
MAX_FILE_UPLOADS_PER_MINUTE=10
MAX_WS_PAYLOAD_BYTES=16384
FAILED_LOGIN_LIMIT=5
FAILED_LOGIN_WINDOW_SECONDS=120
TEMP_BLOCK_SECONDS=180
DISCONNECT_ANOMALY_LIMIT=6
DISCONNECT_ANOMALY_WINDOW_SECONDS=60

# Existing HTTP rate limits
LOGIN_RATE_WINDOW_MS=60000
LOGIN_RATE_MAX=10

# Phase 3 backup recovery
BACKUP_NODE_PORT=5000
BACKUP_NODE_URL=https://localhost:5000
BACKUP_NODE_SECRET=change_this_backup_shared_secret
RECOVERY_TOKEN_EXPIRY_SECONDS=300
RECOVERY_CHALLENGE_EXPIRY_SECONDS=900
REQUIRE_ALL_USERS_FOR_RECOVERY=true
MAIN_NODE_ID=main-node-1
