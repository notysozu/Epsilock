<div class="panel-card chat-container">
  <div class="chat-header">
    <h3><i class="fa-solid fa-lock"></i> Encrypted Comms Channel</h3>
  </div>
  <div class="chat-onboarding-bar">
    <% if (typeof rooms !== 'undefined' && rooms && rooms.length > 0) { %>
      <label for="roomSelect" class="chat-room-select-wrap">
        <span class="small text-gray">Select Room</span>
        <select id="roomSelect">
          <option value="">Choose a room...</option>
          <% rooms.forEach(function(r) { %>
            <option value="<%= r.roomId %>" <%= (typeof activeRoomId !== 'undefined' && activeRoomId === r.roomId) ? 'selected' : '' %>>
              <%= r.name %> (<%= r.roomId %>)
            </option>
          <% }) %>
        </select>
      </label>
      <button id="joinRoomBtn" type="button" class="btn primary-btn">Join Room</button>
      <span id="sessionStatusText" class="text-gray mono-text">Session not started</span>
    <% } else { %>
      <span class="text-amber">No room assigned. Ask admin to assign your account to a room.</span>
    <% } %>
  </div>
  <div class="chat-thread" id="chatThread">
    <!-- Messages will be loaded here via JS -->
  </div>
  <div class="chat-inputbar">
    <input type="text" id="chatInput" placeholder="Enter encrypted message...">
    <button id="sendBtn" class="btn primary-btn"><i class="fa-solid fa-paper-plane"></i></button>
  </div>
</div>
