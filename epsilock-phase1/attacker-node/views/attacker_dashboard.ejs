<div class="attacker-terminal-header" style="display: flex; justify-content: space-between; font-family: monospace; border-bottom: 1px solid #333; padding-bottom: 10px; margin-bottom: 15px;">
  <div style="color: #0f0;">
    [STATUS: <span id="connStatus"><%= state.connected ? 'CONNECTED' : 'DISCONNECTED' %></span>] | 
    [AUTH: <span id="authStatus"><%= state.authenticated ? 'OK' : 'PENDING' %></span>] | 
    [COVER_MODE: <span id="coverStatus"><%= state.settings.coverTrafficEnabled ? 'ON' : 'OFF' %></span>]
  </div>
  <div style="color: #0f0;">
    [CONFIDENCE: <span id="confidence"><%= state.confidence %></span>] | 
    PKTS (TOT/REAL/COV): 
    <span id="totalPackets"><%= state.stats.totalPackets %></span>/
    <span id="realPackets"><%= state.stats.realPackets %></span>/
    <span id="coverPackets"><%= state.stats.coverPackets %></span>
  </div>
</div>

<section class="card" style="background: transparent; border: none; box-shadow: none;">
  <div class="row" style="margin-bottom: 15px;">
    <h2 style="color: #0f0; font-family: monospace; font-size: 1.1rem; flex: 1;">> INTERCEPTION_STREAM --LIVE</h2>
    <button id="clearBtn" type="button" class="secondary-btn" style="padding: 4px 8px; font-size: 0.8rem;">FLUSH_BUFFER</button>
  </div>
  <table style="font-family: monospace; font-size: 0.9rem; table-layout: fixed; width: 100%;">
    <thead style="color: #0f0; border-bottom: 1px solid #0f0;">
      <tr>
        <th style="width: 80px;">Time</th>
        <th style="width: 110px;">packetId</th>
        <th style="width: 140px;">type</th>
        <th style="width: 90px;">roomId</th>
        <th style="width: 90px;">fromUserId</th>
        <th style="width: 80px;">sizeBytes</th>
        <th style="width: 70px;">isCover</th>
        <th style="width: 80px;">decrypt</th>
        <th>decrypted payload</th>
      </tr>
    </thead>
    <tbody id="packetRows">
      <% state.packets.slice(0, 150).forEach((p) => { %>
        <tr class="<%= p.isCover ? 'row-cover' : 'row-real' %>">
          <td><%= new Date(p.time).toLocaleTimeString() %></td>
          <td class="mono"><%= p.packetId %></td>
          <td><%= p.type %></td>
          <td><%= p.roomId %></td>
          <td><%= p.fromUserId %></td>
          <td><%= p.sizeBytes %></td>
          <td><%= p.isCover ? 'yes' : 'no' %></td>
          <td><%= p.decryptStatus %></td>
          <td class="small"><%= p.decryptedPreview || '-' %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</section>

