<div class="tactical-grid cascading-item">
  <!-- Operation Control Widget -->
  <aside class="ops-control-widget">
    <div class="widget-header">
      <i class="fa-solid fa-gears" id="gearsIcon"></i>
      <h3>Chat Control</h3>
      <button id="toggleSidebarBtn" class="toggle-sidebar-btn"><i class="fa-solid fa-chevron-left"></i></button>
    </div>
    
    <div class="control-section">
      <label>Connection Status</label>
      <div id="connectionStatus" class="status-box">SEARCHING...</div>
    </div>

    <div class="control-section">
      <label>Select Room</label>
      <div class="select-wrapper">
        <select id="roomSelect">
          <option value="">-- No Room Selected --</option>
          <% rooms.forEach((r) => { %>
            <option value="<%= r.roomId %>"><%= r.name || r.roomId %></option>
          <% }) %>
        </select>
        <i class="fa-solid fa-chevron-down"></i>
      </div>
      <button id="joinRoomButton" class="action-btn-glow" disabled>Join Channel</button>
    </div>

    <div class="control-section mt-auto">
      <div class="security-readout">
        <p>SECURE SESSION ACTIVE</p>
        <p>AES-256 ENCRYPTION</p>
        <p>HMAC INTEGRITY</p>
      </div>
    </div>
  </aside>

  <!-- Communication Widget -->
  <section class="comm-thread-widget">
    <div class="widget-header">
      <i class="fa-solid fa-comments"></i>
      <h3>Message Stream</h3>
    </div>
    
    <div class="chat-thread logbox terminal-theme-chat" id="chatLog">
      <div class="system-msg">System ready. Establish a channel connection to begin.</div>
    </div>

    <div class="chat-input-area">
      <div class="input-hub">
        <input id="toUserId" placeholder="To (Optional)">
        <input id="messageInput" placeholder="Enter message..." disabled>
        <button id="sendButton" class="send-trigger" disabled>
          <span>SEND</span>
          <i class="fa-solid fa-paper-plane"></i>
        </button>
      </div>
    </div>
  </section>
</div>

<script>
  window.EPSILOCK_USER = {
    userId: "<%= user._id %>",
    username: "<%= user.username %>"
  };
  window.__CHAT_BOOT = {
    status: <%- JSON.stringify(status) %>
  };
</script>
