<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %></title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/public/styles.css">
</head>
<body class="tactical-layout-minimal <%= bodyView === 'login' ? 'login-view' : '' %>">
  <% if (bodyView !== 'login') { %>
  <nav class="top-nav">
    <div class="nav-left">
      <div class="logo-wrap" style="display: flex; align-items: center; gap: 0.75rem;">
        <img src="/public/images/epsilock_logo.png" alt="Epsilock Logo" style="height: 32px; width: auto; border-radius: 4px;">
        <span>EPSILOCK_USER</span>
      </div>
      <div id="wssStatusChat" class="wss-tag status-offline">WSS: DISCONNECTED</div>
    </div>
    <div class="nav-right">
      <div class="mini-profile">
        <div class="avatar">U</div>
        <div class="profile-info">
          <span class="username"><%= (data && data.user) ? data.user.username : 'User' %></span>
          <span class="role">NODE_LINK</span>
        </div>
      </div>
      <% if (bodyView !== 'login') { %>
        <form method="post" action="/logout" class="nm"><button type="submit" class="logout-pill">SECURE_EXIT</button></form>
      <% } %>
    </div>
  </nav>
  <% } %>

  <main class="main-wrapper">
  <% if (bodyView !== 'login') { %>
    <header class="view-header">
      <div class="view-title">
        <h1><%= title %></h1>
        <p class="muted">Secure Tactical Uplink Active</p>
      </div>
      <div class="view-meta">
        <span class="timestamp" id="liveClock">--:--:--</span>
      </div>
    </header>
  <% } %>
    <div class="view-content">
      <%- include(bodyView, data || {}) %>
    </div>
  </main>
  <script src="/public/chat.js"></script>
</body>
</body>
</html>
