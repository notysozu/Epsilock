<div class="traffic-manager-root">
<p class="muted">Cover traffic does not replace encryption. It reduces metadata leakage and timing analysis usefulness.</p>
<section class="card">
  <h2>Current Cover Traffic Settings</h2>
  <p><strong>Attacker Demo Enabled:</strong> <span id="attackerDemoEnabledLabel"><%= securitySettings.attackerDemoEnabled ? 'ON' : 'OFF' %></span></p>
  <p><strong>Cover Traffic:</strong> <span id="coverTrafficEnabledLabel"><%= coverEnabled ? 'ON' : 'OFF' %></span></p>
  <p class="muted">
    Interval: <span id="coverTrafficIntervalMsLabel"><%= securitySettings.coverTrafficIntervalMs %></span>ms,
    Jitter: <span id="coverTrafficJitterMsLabel"><%= securitySettings.coverTrafficJitterMs %></span>ms,
    Ratio: <span id="coverTrafficRatioLabel"><%= securitySettings.coverTrafficRatio %></span>
  </p>
  <p><a href="/admin/security-settings">Manage in Security Settings</a></p>
  <form method="post" action="/admin/attacker-demo/clear"><button type="submit">Clear Demo Logs</button></form>
</section>

<section class="card">
  <h2>Demo Actions</h2>
  <form method="post" action="/admin/attacker-demo/send-sample" class="row">
    <select name="roomId"><% rooms.forEach((r) => { %><option value="<%= r.roomId %>"><%= r.roomId %></option><% }) %></select>
    <select name="fromUserId"><% users.forEach((u) => { %><option value="<%= u._id %>"><%= u.username %></option><% }) %></select>
    <select name="toUserId"><% users.forEach((u) => { %><option value="<%= u._id %>"><%= u.username %></option><% }) %></select>
    <input name="nodeId" placeholder="nodeId" required>
    <button type="submit">Send Sample Real Message</button>
  </form>
  <form method="post" action="/admin/attacker-demo/cover-burst" class="row">
    <select name="roomId"><% rooms.forEach((r) => { %><option value="<%= r.roomId %>"><%= r.roomId %></option><% }) %></select>
    <select name="fromUserId"><% users.forEach((u) => { %><option value="<%= u._id %>"><%= u.username %></option><% }) %></select>
    <select name="toUserId"><% users.forEach((u) => { %><option value="<%= u._id %>"><%= u.username %></option><% }) %></select>
    <input name="nodeId" placeholder="nodeId" required>
    <button type="submit">Generate Cover Burst</button>
  </form>
</section>

<div class="grid two">
  <section class="card terminal-window cascading-item">
    <div class="terminal-header" onclick="this.parentElement.classList.toggle('collapsed')">
      <div class="dot red"></div><div class="dot amber"></div><div class="dot green"></div>
      <span class="terminal-title">TRAFFIC_STREAM: WITHOUT_COVER</span>
      <i class="fa-solid fa-chevron-up collapse-icon"></i>
    </div>
    <div class="terminal-body logbox">
      <div class="terminal-meta">Confidence: <span class="confidence-badge high"><%= confidenceWithout %></span></div>
      <div class="table-wrap">
      <table class="data-table">
        <thead><tr><th>TIME</th><th>SRC</th><th>DST</th><th>SIZE</th><th>TYPE</th><th>DECRYPTED</th></tr></thead>
        <tbody>
          <% withoutCover.slice(0, 50).forEach((p) => { %>
            <tr class="packet-row <%= p.type === 'REAL_MESSAGE' ? 'real' : '' %>">
              <td><%= new Date(p.createdAt).toLocaleTimeString([], {hour12:false}) %></td>
              <td><%= p.fromUserId ? String(p.fromUserId).slice(-4) : '----' %></td>
              <td><%= p.toUserId ? String(p.toUserId).slice(-4) : '----' %></td>
              <td><%= p.sizeBytes %>B</td>
              <td><%= p.type %></td>
              <td class="small-mono"><%= p.decrypted || '[ENCRYPTED_BLOB]' %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
      </div>
    </div>
  </section>

  <section class="card terminal-window cascading-item">
    <div class="terminal-header" onclick="this.parentElement.classList.toggle('collapsed')">
      <div class="dot red"></div><div class="dot amber"></div><div class="dot green"></div>
      <span class="terminal-title">TRAFFIC_STREAM: WITH_COVER</span>
      <i class="fa-solid fa-chevron-up collapse-icon"></i>
    </div>
    <div class="terminal-body logbox">
      <div class="terminal-meta">Confidence: <span class="confidence-badge <%= confidenceWith === 'LOW' ? 'low' : 'medium' %>"><%= confidenceWith %></span></div>
      <div class="table-wrap">
      <table class="data-table">
        <thead><tr><th>TIME</th><th>SRC</th><th>DST</th><th>SIZE</th><th>TYPE</th><th>COVER</th><th>DECRYPTED</th></tr></thead>
        <tbody>
          <% withCover.slice(0, 50).forEach((p) => { %>
            <tr class="packet-row <%= p.isCover ? 'cover' : 'real' %>">
              <td><%= new Date(p.createdAt).toLocaleTimeString([], {hour12:false}) %></td>
              <td><%= p.fromUserId ? String(p.fromUserId).slice(-4) : '----' %></td>
              <td><%= p.toUserId ? String(p.toUserId).slice(-4) : '----' %></td>
              <td><%= p.sizeBytes %>B</td>
              <td><%= p.type %></td>
              <td><%= p.isCover ? 'YES' : 'NO' %></td>
              <td class="small-mono"><%= p.decrypted || '[ENCRYPTED_BLOB]' %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
      </div>
    </div>
  </section>
</div>
