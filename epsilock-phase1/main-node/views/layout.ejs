<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %></title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/public/styles.css">
</head>
<body class="tactical-layout <%= (data && data.pageClass) ? data.pageClass : '' %> <%= bodyView === 'login' ? 'login-view' : '' %>">
  <% if (bodyView !== 'login') { %>
  <div class="sidebar">
    <div class="sidebar-header">
      <div class="logo-wrap" style="display: flex; align-items: center; gap: 0.75rem;">
        <img src="/public/images/epsilock_logo.png" alt="Epsilock Logo" style="height: 32px; width: auto; border-radius: 4px;">
        <span>EPSILOCK</span>
      </div>
      <div id="globalWssStatus" class="wss-tag status-offline">WSS: DISCONNECTED</div>
    </div>
    
    <nav class="sidebar-nav">
      <div class="nav-section">ADMIN DASHBOARD</div>
      <a href="/admin" class="<%= title === 'Admin Dashboard' ? 'active' : '' %>"><i class="fa-solid fa-gauge"></i> Overview</a>
      <a href="/admin/users" class="<%= title === 'Admin Users' ? 'active' : '' %>"><i class="fa-solid fa-users-gear"></i> Users</a>
      <a href="/admin/rooms" class="<%= title === 'Admin Rooms' ? 'active' : '' %>"><i class="fa-solid fa-door-open"></i> Rooms</a>
      <a href="/admin/nodes" class="<%= title === 'Admin Nodes' ? 'active' : '' %>"><i class="fa-solid fa-network-wired"></i> Nodes</a>
      <a href="/admin/incidents" class="<%= title === 'Admin Incidents' ? 'active' : '' %>"><i class="fa-solid fa-triangle-exclamation"></i> Incidents</a>
      
      <div class="nav-section">SECURITY OPS</div>
      <a href="/admin/attacker-demo" class="<%= title === 'Attacker Demo' ? 'active' : '' %>"><i class="fa-solid fa-user-secret"></i> Traffic Manager</a>
      <a href="/admin/security-settings" class="<%= title === 'Security Settings' ? 'active' : '' %>"><i class="fa-solid fa-sliders"></i> System Config</a>
    </nav>

    <div class="sidebar-footer">
      <div class="admin-profile">
        <div class="avatar">A</div>
        <div class="profile-info">
          <span class="username">Admin</span>
          <span class="role">Root Access</span>
        </div>
      </div>
      <form method="post" action="/logout" style="width:100%"><button type="submit" class="logout-btn">LOGOUT</button></form>
    </div>
  </div>
  <% } %>

  <main class="content-area">
    <% if (bodyView !== 'login') { %>
    <header class="content-header">
      <h1><%= title %></h1>
      <div class="header-actions">
        <span class="timestamp" id="liveClock">--:--:--</span>
      </div>
    </header>
    <% } %>
    <div class="scroll-container">
      <%- include(bodyView, data || {}) %>
    </div>
  </main>
  <script>window.__ADMIN_TOKEN = '<%= (data && data.admin && data.admin.token) ? data.admin.token : '' %>';</script>
  <script src="/public/admin.js"></script>
</body>
</html>
