<div class="dashboard-root">
<div class="grid four cascading-item">
  <article class="card mini-stat">
    <span class="label">USERS</span>
    <span class="value"><%= stats.users %></span>
  </article>
  <article class="card mini-stat">
    <span class="label">ROOMS</span>
    <span class="value"><%= stats.rooms %></span>
  </article>
  <article class="card mini-stat">
    <span class="label">ONLINE_NODES</span>
    <span class="value"><%= stats.onlineNodes %></span>
  </article>
  <article class="card mini-stat alert">
    <span class="label">INCIDENTS</span>
    <span class="value"><%= stats.incidents %></span>
  </article>
</div>

<div class="grid four cascading-item">
  <article class="card mini-stat real">
    <span class="label">REAL_PACKETS</span>
    <span class="value"><%= stats.real %></span>
  </article>
  <article class="card mini-stat cover">
    <span class="label">COVER_PACKETS</span>
    <span class="value"><%= stats.cover %></span>
  </article>
  <article class="card mini-stat total">
    <span class="label">RAW_TRAFFIC</span>
    <span class="value"><%= stats.total %></span>
  </article>
  <article class="card mini-stat confidence">
    <span class="label">ATTACKER_CONFIDENCE</span>
    <div class="value-wrap mt-4">
      <span class="badge <%= stats.confidence === 'LOW' ? 'bg-red' : 'bg-green' %>"><%= stats.confidence %></span>
    </div>
  </article>
</div>

<div class="grid two">
  <section class="card cascading-item">
    <h2>SYSTEM_STATUS</h2>
    <div class="status-grid stack">
      <div class="status-row">
        <span>Attacker Demo State</span>
        <span class="badge <%= securitySettings.attackerDemoEnabled ? 'bg-green' : 'bg-red' %>" id="attackerDemoEnabledLabel"><%= securitySettings.attackerDemoEnabled ? 'ACTIVE' : 'OFF' %></span>
      </div>
      <div class="status-row">
        <span>Cover Traffic Mode</span>
        <span class="badge <%= securitySettings.coverTrafficEnabled ? 'bg-blue' : 'bg-red' %>" id="coverTrafficEnabledLabel"><%= securitySettings.coverTrafficEnabled ? 'ENFORCED' : 'OFF' %></span>
      </div>
      <div class="status-row">
        <span>Attacker Uplink</span>
        <span class="badge <%= attackerStatus.connected ? 'bg-green' : 'bg-red' %>" id="attackerNodeConnectedLabel"><%= attackerStatus.connected ? 'ESTABLISHED' : 'DOWN' %></span>
      </div>
    </div>
    <div class="row mt-4">
      <a href="/admin/security-settings"><button type="button">CONFIG</button></a>
      <a href="/admin/attacker-demo"><button type="button">TRAFFIC</button></a>
    </div>
  </section>

  <section class="card cascading-item">
    <h2>SECURITY_FEED</h2>
    <div id="adminAlerts" class="logbox terminal-style-small"></div>
  </section>
</div>

<section class="card cascading-item">
  <h2>INCIDENT_LOG</h2>
  <div class="table-wrap">
    <table class="data-table">
      <thead><tr><th>ID</th><th>Type</th><th>Severity</th><th>Reason</th><th>Time</th></tr></thead>
      <tbody>
        <% incidents.forEach((i) => { %>
          <tr class="<%= i.severity === 'high' ? 'text-red' : '' %>">
            <td><%= i.incidentId %></td>
            <td><%= i.type %></td>
            <td><%= i.severity %></td>
            <td><%= i.reason %></td>
            <td><%= new Date(i.createdAt).toLocaleString() %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>
