<div class="settings-root">
<p class="muted">Global controls are persisted and pushed to all user nodes live (no restart).</p>

<section class="card cascading-item">
  <form id="securitySettingsForm" class="stack">
    <div class="grid two">
      <div class="form-group">
        <label>Attacker Demo</label>
        <select name="attackerDemoEnabled" id="attackerDemoEnabled">
          <option value="true" <%= settings.attackerDemoEnabled ? 'selected' : '' %>>ACTIVE</option>
          <option value="false" <%= !settings.attackerDemoEnabled ? 'selected' : '' %>>DISABLED</option>
        </select>
      </div>

      <div class="form-group">
        <label>Cover Traffic Status</label>
        <select name="coverTrafficEnabled" id="coverTrafficEnabled">
          <option value="true" <%= settings.coverTrafficEnabled ? 'selected' : '' %>>ACTIVE (MIXED MODE)</option>
          <option value="false" <%= !settings.coverTrafficEnabled ? 'selected' : '' %>>DISABLED (CLEAN MODE)</option>
        </select>
      </div>
    </div>

    <div class="slider-control-row mt-4">
      <div class="slider-info">
        <span>Cover Traffic Interval (ms)</span>
        <span class="badge bg-blue" id="val_interval"><%= settings.coverTrafficIntervalMs %> ms</span>
      </div>
      <input type="range" name="coverTrafficIntervalMs" id="coverTrafficIntervalMs" min="100" max="10000" step="100" value="<%= settings.coverTrafficIntervalMs %>" oninput="document.getElementById('val_interval').innerText = this.value + ' ms'">
    </div>

    <div class="slider-control-row">
      <div class="slider-info">
        <span>Cover Traffic Jitter (ms)</span>
        <span class="badge bg-amber" id="val_jitter"><%= settings.coverTrafficJitterMs %> ms</span>
      </div>
      <input type="range" name="coverTrafficJitterMs" id="coverTrafficJitterMs" min="0" max="5000" step="50" value="<%= settings.coverTrafficJitterMs %>" oninput="document.getElementById('val_jitter').innerText = this.value + ' ms'">
    </div>

    <div class="slider-control-row">
      <div class="slider-info">
        <span>Cover Traffic Ratio</span>
        <span class="badge bg-green" id="val_ratio">1 : <%= settings.coverTrafficRatio %></span>
      </div>
      <input type="range" name="coverTrafficRatio" id="coverTrafficRatio" min="1" max="20" step="1" value="<%= settings.coverTrafficRatio %>" oninput="document.getElementById('val_ratio').innerText = '1 : ' + this.value">
    </div>

    <div class="row mt-4">
      <button type="submit" class="primary-btn">APPLY SECURITY PARAMS</button>
      <button type="button" id="refreshSettingsBtn" class="secondary-btn">SYNC FROM SERVER</button>
    </div>
  </form>

  <p id="settingsSaveStatus" class="muted mt-4">System last updated: <%= settings.updatedAt ? new Date(settings.updatedAt).toLocaleString() : 'NEVER' %></p>
</section>
